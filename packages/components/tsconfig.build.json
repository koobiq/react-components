{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "emitDeclarationOnly": true,
    "skipLibCheck": true,
    "rootDir": "./src",
    "outDir": "./dist",
    "paths": {}
  },
  "exclude": [
    "**/*/__tests__/*",
    "**/*/__testfixtures__/*",
    "**/*.test.*",
    "**/*.stories.*",
    "setupTests.ts"
  ]
}
