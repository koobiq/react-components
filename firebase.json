{
  "hosting": [
    {
      "target": "stable",
      "public": "storybook-static",
      "cleanUrls": true,
      "rewrites": [
        {
          "source": "/**/!(*.@(js|ts|html|css|json|svg|png|jpg|jpeg))",
          "destination": "/index.html"
        }
      ],
      "headers": [
        {
          "source": "/**",
          "headers": [
            {
              "key": "Cache-Control",
              // Storybook shell, indexes, manifests, manager and add-ons are not reliably hashed.
              "value": "no-cache, must-revalidate"
            },
            {
              "key": "X-XSS-Protection",
              "value": "1"
            }
          ]
        },
        {
          "source": "/assets/**",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "public, max-age=31536000, immutable"
            }
          ]
        }
      ],
      "ignore": ["firebase.json", "**/node_modules/**"]
    },
    {
      "target": "next",
      "public": "storybook-static",
      "cleanUrls": true,
      "rewrites": [
        {
          "source": "/**/!(*.@(js|ts|html|css|json|svg|png|jpg|jpeg))",
          "destination": "/index.html"
        }
      ],
      "headers": [
        {
          "source": "/**",
          "headers": [
            {
              "key": "Cache-Control",
              // Storybook shell, indexes, manifests, manager and add-ons are not reliably hashed.
              "value": "no-cache, must-revalidate"
            },
            {
              "key": "X-XSS-Protection",
              "value": "1"
            }
          ]
        },
        {
          "source": "/assets/**",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "public, max-age=31536000, immutable"
            }
          ]
        }
      ],
      "ignore": ["firebase.json", "**/node_modules/**"]
    }
  ]
}
