{
  "$schema": "https://developer.microsoft.com/json-schemas/api-extractor/v7/api-extractor.schema.json",
  "mainEntryPointFilePath": "<projectFolder>/packages/components/dist/index.d.ts",
  "bundledPackages": [],
  "compiler": {
    "tsconfigFilePath": "<projectFolder>/tools/api-extractor/tsconfig.json"
  },
  "apiReport": {
    "enabled": true,
    "reportFileName": "report.api.md",
    "reportTempFolder": "<projectFolder>/tools/public_api_guard/temp",
    "reportFolder": "<projectFolder>/tools/public_api_guard"
  },
  "docModel": { "enabled": false },
  "dtsRollup": { "enabled": false },
  "tsdocMetadata": { "enabled": false },
  "messages": {
    "compilerMessageReporting": {
      "default": { "logLevel": "warning" }
    },
    "extractorMessageReporting": {
      "default": { "logLevel": "warning" },
      "ae-missing-release-tag": { "logLevel": "none" },
      "ae-forgotten-export": { "logLevel": "warning" }
    },
    "tsdocMessageReporting": {
      "default": { "logLevel": "none" }
    }
  }
}
